#include <zephyr/dt-bindings/i2c/i2c.h>

/ {
	buttons {
		compatible = "gpio-keys";
		button0: button_0 {
			gpios = <&gpio1 11 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "D2 pairing button";
		};
	};

	aliases {
		accel0 = &lsm9ds1;
		magn0 = &lsm9ds1_mag;
		sw0 = &button0;
	};
};

&i2c1 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	lsm9ds1: lsm9ds1@6b {
		compatible = "st,lsm9ds1-local";
		reg = <0x6b>;
		status = "okay";
	};

	lsm9ds1_mag: lsm9ds1-mag@1e {
		compatible = "st,lsm9ds1-mag-local";
		reg = <0x1e>;
		status = "okay";
	};
};
